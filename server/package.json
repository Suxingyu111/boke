{
  "name": "blog-server",
  "version": "1.0.0",
  "description": "Personal blog system backend with NestJS",
  "author": "Blog Author",
  "private": true,
  "packageManager": "npm@10.8.2",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "docs:generate": "node -r tsconfig-paths/register ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/generate-openapi.ts",
    "sbom:generate": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/generate-sbom.ts",
    "supply-chain:verify": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/verify-supply-chain.ts",
    "supply-chain:scan": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/scan-pinned-images.ts",
    "backup:drill": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/run-backup-drill.ts",
    "db:init": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/init-db.ts",
    "db:seed:about": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/seed-about.ts",
    "db:seed-content": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/seed-content.ts",
    "db:seed-bulk": "node ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/seed-bulk-articles.ts",
    "search:refresh-local": "node -r tsconfig-paths/register ./node_modules/ts-node/dist/bin.js --project tsconfig.json scripts/seed-and-reindex.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "typeorm migration:run",
    "migration:revert": "typeorm migration:revert"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.13.1",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/sharp": "^0.31.1",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "mysql2": "^3.6.0",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "redis": "^4.6.10",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.2.0",
    "@types/bcrypt": "^5.0.1",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^5.2.0"
  }
}
