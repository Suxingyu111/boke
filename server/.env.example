# Application
NODE_ENV=development
PORT=3000
APP_NAME=Blog System
APP_DESC=Personal Blog System API
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:4173
CORS_ALLOW_REQUESTS_WITHOUT_ORIGIN=true
CORS_ALLOWED_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,Origin,X-CSRF-Token,X-Requested-With
CORS_EXPOSED_HEADERS=Content-Disposition,X-Cache
CORS_MAX_AGE_SECONDS=600
TRUST_PROXY=false
SECURITY_HSTS_ENABLED=false
SECURITY_CSP_REPORT_ONLY=true
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=accelerometer=(), autoplay=(), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), usb=(), xr-spatial-tracking=()
SECURITY_ALERT_RECIPIENTS=root@example.com
SECURITY_ALERT_COOLDOWN_SECONDS=300

# Database - MySQL
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=blog_user
DB_PASSWORD=change_me_db_password
DB_DATABASE=blog_system
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_POOL_SIZE=10
BACKUP_DRILL_DATABASE=blog_system_drill
BACKUP_DRILL_CLEANUP=true
BACKUP_DRILL_RTO_SECONDS=900
BACKUP_DRILL_RPO_SECONDS=86400

# Docker Compose MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=blog_user
MYSQL_PASSWORD=change_me_db_password
MYSQL_DATABASE=blog_system

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password_strong
REDIS_DB=0

# JWT
JWT_SECRET=change_me_to_a_32_plus_char_random_secret
JWT_EXPIRATION=7d
AUTH_COOKIE_NAME=blog_auth_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=strict
AUTH_STEP_UP_COOKIE_NAME=blog_admin_step_up
AUTH_STEP_UP_COOKIE_PATH=/api/admin
AUTH_STEP_UP_TTL=10m
AUTH_STEP_UP_WINDOW_MS=600000
CLIENT_URL=http://localhost:5173

# OAuth（可选）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Super Admin（推荐使用 SUPER_ADMIN_*；ADMIN_* 仅保留兼容）
SUPER_ADMIN_USERNAME=rootmaster
SUPER_ADMIN_PASSWORD=change_me_super_admin_password_strong
SUPER_ADMIN_EMAIL=root@example.com
SUPER_ADMIN_NICKNAME=系统超管
ADMIN_USERNAME=
ADMIN_PASSWORD=

# API docs
SWAGGER_ENABLED=true
