# Application
NODE_ENV=development
PORT=3000
APP_NAME=Blog System
APP_DESC=Personal Blog System API
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:4173

# Database - MySQL
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=blog_user
DB_PASSWORD=change_me_db_password
DB_DATABASE=blog_system
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Docker Compose MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=blog_user
MYSQL_PASSWORD=change_me_db_password
MYSQL_DATABASE=blog_system

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password_strong
REDIS_DB=0

# JWT
JWT_SECRET=change_me_to_a_32_plus_char_random_secret
JWT_EXPIRATION=7d

# Admin
ADMIN_USERNAME=admin_manager
ADMIN_PASSWORD=change_me_admin_password_strong
