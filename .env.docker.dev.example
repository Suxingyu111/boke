# 开发环境 Docker Compose 模板
# 使用方式：
# cp .env.docker.dev.example .env.docker.dev
# docker compose --env-file .env.docker.dev -f docker-compose.yml up -d --build

# ========== 对外入口 ==========
NGINX_HOST_PORT=80
SERVER_HOST_PORT=3000
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
ES_HOST_PORT=9200
KIBANA_HOST_PORT=5601

# ========== 站点与 API ==========
NODE_ENV=development
APP_NAME=Blog System Dev
APP_DESC=Personal Blog System API (Development)
CLIENT_URL=http://localhost
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change_me_to_a_32_plus_char_random_dev_secret
JWT_EXPIRATION=7d
AUTH_COOKIE_NAME=blog_auth_token
AUTH_STEP_UP_COOKIE_NAME=blog_admin_step_up
AUTH_STEP_UP_TTL=10m
AUTH_STEP_UP_WINDOW_MS=600000

# ========== MySQL ==========
MYSQL_ROOT_PASSWORD=change_me_to_a_strong_local_root_password
MYSQL_DATABASE=blog_system_dev
MYSQL_USER=blog_user
MYSQL_PASSWORD=change_me_to_a_strong_local_app_password

# ========== Redis ==========
REDIS_PASSWORD=change_me_to_a_strong_local_redis_password

# ========== Elasticsearch / Kibana ==========
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ========== 超级管理员 ==========
SUPER_ADMIN_USERNAME=rootmaster
SUPER_ADMIN_PASSWORD=change_me_to_a_strong_local_admin_password
SUPER_ADMIN_EMAIL=admin@localhost.dev
SUPER_ADMIN_NICKNAME=开发环境超管

# ========== SMTP（可选） ==========
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ========== 前端构建 ==========
VITE_PAGE_CACHE_TTL=1000

# ========== 容器启动初始化 ==========
# 开发环境默认打开初始化和索引重建，是否灌入演示数据可自行切换
DOCKER_BOOTSTRAP_INIT_DB=true
DOCKER_BOOTSTRAP_SEED_DEMO=true
DOCKER_BOOTSTRAP_REINDEX=true
DOCKER_BOOTSTRAP_WAIT_TIMEOUT_MS=180000

# ========== 数据库同步策略 ==========
DB_SYNCHRONIZE=false
